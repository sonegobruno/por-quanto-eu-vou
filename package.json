{
  "name": "por-quanto-eu-vou",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "serve:ssr:por-quanto-eu-vou": "node dist/por-quanto-eu-vou/server/server.mjs",
    "lint": "ng lint",
    "format": "prettier --write \"src/**/*.{ts,scss,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,scss,json}\"",
    "test": "ng test --watch=false",
    "test:watch": "ng test",
    "test:coverage": "ng test --coverage",
    "prepare": "husky",
    "commit": "cz"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "src/**/*.{scss,json}": [
      "prettier --write"
    ]
  },
  "private": true,
  "packageManager": "npm@11.11.0",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/platform-server": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@angular/ssr": "^21.2.7",
    "express": "^5.1.0",
    "ngx-logger": "^5.0.12",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.7",
    "@angular/cli": "^21.2.7",
    "@angular/compiler-cli": "^21.2.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.19.39",
    "@vitest/coverage-v8": "^4.1.4",
    "angular-eslint": "21.3.1",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "jest-preset-angular": "^16.1.4",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.2",
    "ts-jest": "^29.4.9",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.56.1"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "type": "module"
}
